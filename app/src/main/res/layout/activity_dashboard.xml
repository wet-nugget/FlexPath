<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_blue">

    <!-- Background Image -->
    <ImageView
        android:id="@+id/imageviewBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_dark_geometric"
        android:scaleType="centerCrop"
        android:alpha="0.3"
        android:contentDescription="@null"/>

    <!-- Logout View -->
    <TextView
        android:id="@+id/textviewLogout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/logout"
        android:textColor="@color/yellow"
        android:textSize="14sp"
        android:layout_marginRight="24dp"
        android:layout_marginTop="24dp"
        android:layout_alignParentRight="true"
        android:fontFamily="@font/allerta_stencil"/>

    <!-- Greeting -->
    <TextView
        android:id="@+id/textviewGreeting"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/greeting_text"
        android:textColor="@color/white"
        android:textSize="50sp"
        android:textStyle="bold"
        android:layout_marginTop="30dp"
        android:layout_marginStart="24dp"
        android:fontFamily="@font/allerta_stencil"/>

    <!-- Subheading -->
    <TextView
        android:id="@+id/textviewSubheading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/ready_to_train"
        android:textColor="@color/white"
        android:textSize="12sp"
        android:layout_below="@id/textviewGreeting"
        android:layout_marginStart="24dp"
        android:fontFamily="@font/allerta_stencil"/>

    <!-- Workout Options -->
    <LinearLayout
        android:id="@+id/layoutWorkouts"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_below="@id/textviewSubheading"
        android:layout_marginTop="24dp"
        android:layout_marginHorizontal="16dp">

        <!-- Upper Body Card -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="@drawable/card_background"
            android:layout_marginBottom="16dp">

            <ImageView
                android:id="@+id/imageviewUpperBody"
                android:layout_width="100dp"
                android:layout_height="match_parent"
                android:src="@drawable/ic_upper_body"
                android:scaleType="centerCrop"
                android:layout_alignParentStart="true"
                android:contentDescription="@string/upper_body_desc"/>

            <TextView
                android:id="@+id/textviewUpperBodyTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/upper_body"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="30sp"
                android:layout_toEndOf="@id/imageviewUpperBody"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:fontFamily="@font/allerta_stencil"/>

            <TextView
                android:id="@+id/textviewUpperBodyDetails"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/upper_body_details"
                android:textColor="@color/dark_blue2"
                android:textSize="12sp"
                android:layout_below="@id/textviewUpperBodyTitle"
                android:layout_toEndOf="@id/imageviewUpperBody"
                android:layout_marginStart="16dp"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/allerta_stencil"/>
        </RelativeLayout>

        <!-- Lower Body Card -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="@drawable/card_background">

            <ImageView
                android:id="@+id/imageviewLowerBody"
                android:layout_width="100dp"
                android:layout_height="match_parent"
                android:src="@drawable/ic_lower_body"
                android:scaleType="centerCrop"
                android:layout_alignParentStart="true"
                android:contentDescription="@string/lower_body_desc"/>

            <TextView
                android:id="@+id/textviewLowerBodyTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/lower_body"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="30sp"
                android:layout_toEndOf="@id/imageviewLowerBody"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:fontFamily="@font/allerta_stencil"/>

            <TextView
                android:id="@+id/textviewLowerBodyDetails"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/lower_body_details"
                android:textColor="@color/dark_blue2"
                android:textSize="12sp"
                android:layout_below="@id/textviewLowerBodyTitle"
                android:layout_toEndOf="@id/imageviewLowerBody"
                android:layout_marginStart="16dp"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/allerta_stencil"/>
        </RelativeLayout>
    </LinearLayout>

    <!-- Bottom Navigation -->
    <LinearLayout
        android:id="@+id/layoutBottomNav"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:layout_alignParentBottom="true"
        android:background="@color/dark_blue">

        <ImageView
            android:id="@+id/iconHome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:src="@drawable/ic_home"
            android:contentDescription="@string/home_desc"
            android:scaleY=".75"
            android:scaleX=".75"
            android:layout_gravity="center"/>

        <ImageView
            android:id="@+id/iconWorkouts"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:src="@drawable/ic_dumbbell"
            android:contentDescription="@string/workouts_desc"
            android:scaleY=".75"
            android:scaleX=".75"
            android:layout_gravity="center"/>

        <ImageView
            android:id="@+id/iconPlans"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:src="@drawable/ic_clipboard"
            android:contentDescription="@string/plans_desc"
            android:scaleY=".75"
            android:scaleX=".75"
            android:layout_gravity="center"/>

        <ImageView
            android:id="@+id/iconProfile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:src="@drawable/ic_user"
            android:contentDescription="@string/profile_desc"
            android:scaleY=".75"
            android:scaleX=".75"
            android:layout_gravity="center"/>
    </LinearLayout>
</RelativeLayout>